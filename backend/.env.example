PORT=4000
DATABASE_FILE=./data/stadium.db
JWT_SECRET=replace-with-a-long-random-local-secret
JWT_EXPIRES_IN=1h
FRONTEND_ORIGIN=http://localhost:5173
GEMINI_API_KEY=
# Lite model default for low-latency assistant text generation
GEMINI_MODEL=gemini-3.1-flash-lite
ENABLE_SIMULATOR=true
# Set true only when you intentionally want Railway/local startup to reseed demo data.
SEED_ON_START=false
